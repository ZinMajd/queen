{
    "version": 2,
    "functions": {
        "public/index.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "public/init_db.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "public/assets/$1"
        },
        {
            "src": "/init-db",
            "dest": "public/init_db.php"
        },
        {
            "src": "/api/(.*)",
            "dest": "public/index.php"
        },
        {
            "src": "/(.*)",
            "dest": "public/index.php"
        }
    ]
}
