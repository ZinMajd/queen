{
  "version": 2,
  "functions": {
    "backend/api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "backend/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "backend/api/index.php"
    }
  ]
}
